  "description": "Model-layer bridge for routing Codex CLI, Claude Code, and similar clients to GitHub Copilot.",
  "keywords": [
    "github-copilot",
    "proxy",
    "bridge",
    "codex",
    "claude"
  ],
  "homepage": "https://github.com/betaHi/copilot-bridge#readme",
  "bugs": {
    "url": "https://github.com/betaHi/copilot-bridge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betaHi/copilot-bridge.git"
  },
  "license": "MIT",
  "author": "betaHi",
  "type": "module",
  "bin": {
    "copilot-bridge": "./dist/main.js",
    "betahi-copilot-bridge": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
